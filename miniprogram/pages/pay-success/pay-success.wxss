/* pages/pay-success/pay-success.wxss */

.page { background: var(--bg); min-height: 100vh; }

/* 顶部成功头 */
.success-header {
  background: linear-gradient(135deg, #6C3CE1 0%, #9B5DE5 50%, #C77DFF 100%);
  padding: 56rpx 40rpx 44rpx;
  display: flex; flex-direction: column; align-items: center;
  position: relative; overflow: hidden;
}
.success-header-bg {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 70% 20%, rgba(240,180,41,0.25) 0%, transparent 55%);
}
.success-circle {
  width: 124rpx; height: 124rpx; border-radius: 50%;
  background: rgba(255,255,255,0.18);
  border: 5rpx solid rgba(255,255,255,0.5);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx; position: relative;
  box-shadow: 0 0 0 16rpx rgba(255,255,255,0.08);
}
.success-icon { font-size: 60rpx; color: #fff; font-weight: 900; }
.success-title { font-size: 40rpx; font-weight: 800; color: #fff; position: relative; }
.success-sub { font-size: 26rpx; color: rgba(255,255,255,0.75); margin-top: 8rpx; position: relative; }

/* 拼团进度卡片 */
.invite-card {
  margin: 28rpx; padding: 36rpx;
}
.invite-card-title { font-size: 32rpx; font-weight: 800; color: var(--text-main); margin-bottom: 4rpx; }
.invite-card-sub { font-size: 26rpx; color: var(--primary); font-weight: 600; margin-bottom: 28rpx; }

/* 进度条 */
.progress-wrap { margin: 0 0 20rpx; }
.progress-label {
  display: flex; justify-content: space-between;
  font-size: 24rpx; color: var(--text-hint); margin-bottom: 12rpx; font-weight: 500;
}
.progress-pct { color: var(--primary); font-weight: 700; }
.progress-bar {
  height: 14rpx; background: var(--bg); border-radius: 8rpx; overflow: hidden;
}
.progress-fill {
  height: 100%; border-radius: 8rpx;
  background: linear-gradient(90deg, #6C3CE1, #C77DFF);
  transition: width 0.5s ease;
}

/* 成员头像 */
.member-row {
  display: flex; gap: 20rpx; margin: 28rpx 0 20rpx; flex-wrap: wrap;
}
.member-slot { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.member-avatar {
  width: 84rpx; height: 84rpx; border-radius: 50%;
  background: rgba(108,60,225,0.1);
  display: flex; align-items: center; justify-content: center;
  border: 4rpx solid rgba(108,60,225,0.2); position: relative;
  box-shadow: 0 4rpx 16rpx rgba(108,60,225,0.15);
}
.avatar-img { width: 84rpx; height: 84rpx; border-radius: 50%; }
.avatar-emoji { font-size: 40rpx; }
.member-avatar.empty {
  background: var(--bg); border: 4rpx dashed var(--border);
  box-shadow: none; font-size: 36rpx; color: var(--text-hint);
}
.member-check {
  position: absolute; bottom: -4rpx; right: -4rpx;
  width: 30rpx; height: 30rpx; border-radius: 50%;
  background: var(--success); color: #fff; font-size: 16rpx;
  display: flex; align-items: center; justify-content: center;
  border: 3rpx solid #fff;
}
.m-label { font-size: 18rpx; color: var(--text-hint); font-weight: 500; }
.m-label.done { color: var(--success); }

/* 倒计时 */
.timer-badge {
  display: flex; align-items: center; gap: 12rpx;
  background: rgba(108,60,225,0.06); border: 2rpx solid rgba(108,60,225,0.12);
  border-radius: var(--radius-sm); padding: 16rpx 24rpx;
  font-size: 26rpx; color: var(--primary); margin: 16rpx 0;
}

/* 分享按钮 */
.btn-share {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  width: 100%; padding: 28rpx; border-radius: 56rpx;
  background: linear-gradient(135deg, #6C3CE1 0%, #9B5DE5 100%);
  color: #fff; font-size: 32rpx; font-weight: 800;
  margin-top: 24rpx; border: none;
  box-shadow: 0 12rpx 44rpx rgba(108,60,225,0.42);
  letter-spacing: 1rpx;
}
.btn-share::after { border: none; }

/* 订单信息卡片 */
.order-info-card {
  margin: 0 28rpx 24rpx; padding: 32rpx;
}
.info-card-title { font-size: 28rpx; font-weight: 800; color: var(--text-main); margin-bottom: 24rpx; }
.info-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14rpx 0; border-bottom: 1rpx solid var(--border); font-size: 26rpx;
}
.info-row:last-child { border-bottom: none; }
.info-key { color: var(--text-hint); font-weight: 500; }
.info-val { color: var(--text-main); font-weight: 600; }
.info-val.purple { color: var(--primary); }
.info-val.green { color: var(--success); }
.info-val.hint { color: var(--text-hint); font-size: 22rpx; }

/* 底部操作 */
.bottom-actions {
  display: flex; gap: 20rpx; margin: 0 28rpx 60rpx;
}
.btn-mini {
  flex: 1; padding: 22rpx; border-radius: 48rpx; text-align: center;
  font-size: 28rpx; font-weight: 700;
}
.btn-mini.outline {
  border: 3rpx solid var(--border); color: var(--text-sub); background: var(--card);
}
.btn-mini.primary {
  border: 3rpx solid rgba(108,60,225,0.25); color: var(--primary);
  background: rgba(108,60,225,0.06);
}
