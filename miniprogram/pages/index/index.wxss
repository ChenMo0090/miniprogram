/* pages/index/index.wxss */

.page { background: var(--bg); min-height: 100vh; }

/* 顶部渐变 */
.home-top {
  background: linear-gradient(135deg, #6C3CE1 0%, #9B5DE5 50%, #C77DFF 100%);
  padding: 24rpx 28rpx 28rpx;
}
.top-row {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24rpx;
}
.logo { font-size: 32rpx; font-weight: 800; color: #fff; letter-spacing: 1rpx; }
.notice-badge {
  display: flex; align-items: center; gap: 8rpx;
  background: rgba(255,255,255,0.15); border: 1rpx solid rgba(255,255,255,0.25);
  border-radius: 40rpx; padding: 8rpx 20rpx;
  font-size: 22rpx; color: rgba(255,255,255,0.9);
  backdrop-filter: blur(8rpx);
}
.search-box {
  background: rgba(255,255,255,0.96); border-radius: 44rpx;
  padding: 18rpx 28rpx; display: flex; align-items: center; gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.12);
}
.search-icon { color: var(--primary); font-size: 28rpx; }
.search-input {
  flex: 1; font-size: 28rpx; color: var(--text-main);
  background: transparent;
}
.search-clear { color: var(--text-hint); font-size: 28rpx; padding: 0 4rpx; }

/* Banner */
.banner { height: 280rpx; }
.banner-inner {
  height: 280rpx;
  background: linear-gradient(135deg, #4A1FA8 0%, #6C3CE1 40%, #9B5DE5 70%, #C77DFF 100%);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40rpx;
  position: relative; overflow: hidden;
}
.banner-inner::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(circle at 70% 30%, rgba(240,180,41,0.3) 0%, transparent 50%);
}
.banner-content { position: relative; z-index: 1; }
.banner-title {
  font-size: 44rpx; font-weight: 800; color: #fff;
  letter-spacing: 1rpx;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}
.banner-em { color: #FDE68A; }
.banner-sub { font-size: 24rpx; color: rgba(255,255,255,0.85); margin-top: 10rpx; }
.banner-badge {
  display: inline-block; margin-top: 18rpx;
  background: linear-gradient(135deg, #F0B429 0%, #FDE68A 100%);
  color: #7B4900; font-size: 22rpx; font-weight: 700;
  padding: 8rpx 24rpx; border-radius: 40rpx;
}
.banner-deco { font-size: 100rpx; position: relative; z-index: 1; }

/* 分类栏 */
.category-bar {
  background: var(--card); padding: 24rpx 16rpx 16rpx;
  display: flex; border-bottom: 1rpx solid var(--border);
}
.cat-item {
  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  font-size: 22rpx; color: var(--text-sub); font-weight: 500;
}
.cat-item.active { color: var(--primary); font-weight: 700; }
.cat-icon {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; background: var(--bg);
}
.cat-item.active .cat-icon { background: rgba(108,60,225,0.12); }
.cat-name { font-size: 22rpx; }

/* 商品网格 */
.product-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 20rpx; padding: 0 24rpx 24rpx;
  background: var(--bg);
}
.product-card {
  background: var(--card); border-radius: var(--radius);
  box-shadow: var(--shadow-sm); overflow: hidden;
}
.product-img {
  width: 100%; height: 260rpx;
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
.img-real { width: 100%; height: 260rpx; }
.img-emoji { font-size: 96rpx; }
.img-bg1 { background: linear-gradient(135deg, #EDE9FE, #DDD6FE); }
.img-bg2 { background: linear-gradient(135deg, #D1FAE5, #A7F3D0); }
.img-bg3 { background: linear-gradient(135deg, #FEF3C7, #FDE68A); }
.img-bg4 { background: linear-gradient(135deg, #FCE7F3, #FBCFE8); }
.activity-badge {
  position: absolute; top: 14rpx; left: 14rpx;
  background: linear-gradient(135deg, #6C3CE1, #9B5DE5);
  color: #fff; font-size: 18rpx; font-weight: 700;
  padding: 6rpx 14rpx; border-radius: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(108,60,225,0.4);
}
.product-info { padding: 16rpx 20rpx 20rpx; }
.product-name {
  font-size: 26rpx; line-height: 1.5; color: var(--text-main);
  font-weight: 500; margin-bottom: 12rpx;
  overflow: hidden; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.price-row { display: flex; align-items: baseline; gap: 10rpx; }
.price { font-size: 32rpx; font-weight: 800; color: var(--primary); }
.price-unit { font-size: 22rpx; }
.original-price { font-size: 22rpx; color: var(--text-hint); text-decoration: line-through; }
.sales-count { font-size: 20rpx; color: var(--text-hint); margin-top: 6rpx; }

/* 加载/无更多 */
.load-more {
  display: flex; justify-content: center; padding: 40rpx 0;
}
.loading-dots { display: flex; gap: 12rpx; align-items: center; }
.loading-dots .dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: var(--primary); opacity: 0.4;
  animation: bounce 1.2s infinite;
}
.loading-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dots .dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
  40%            { transform: scale(1);   opacity: 1; }
}
.no-more {
  text-align: center; padding: 40rpx 0; font-size: 24rpx; color: var(--text-hint);
}
