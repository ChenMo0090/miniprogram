/* pages/group-detail/group-detail.wxss */

.page { background: var(--bg); min-height: 100vh; padding-bottom: 160rpx; }

/* 顶部状态栏 */
.status-bar {
  background: linear-gradient(135deg, #6C3CE1 0%, #9B5DE5 100%);
  padding: 40rpx 28rpx 36rpx; color: #fff; text-align: center;
  position: relative;
}
.status-bar.success { background: linear-gradient(135deg, #065F46, #10B981); }
.status-bar.failed  { background: linear-gradient(135deg, #374151, #6B7280); }
.nav-back-wrap {
  position: absolute; left: 28rpx; top: 50%; transform: translateY(-50%);
}
.nav-back-text { font-size: 52rpx; color: rgba(255,255,255,0.9); }
.status-main { font-size: 36rpx; font-weight: 800; letter-spacing: 1rpx; }
.status-sub { font-size: 24rpx; opacity: 0.8; margin-top: 10rpx; }

/* 进度卡片 */
.progress-card { margin: 24rpx; padding: 32rpx; }
.progress-header-row {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx;
}
.progress-title { font-size: 30rpx; font-weight: 800; color: var(--text-main); }
.countdown-badge {
  display: flex; align-items: center; gap: 8rpx;
  font-size: 26rpx; color: var(--primary); background: rgba(108,60,225,0.08);
  padding: 8rpx 20rpx; border-radius: 24rpx; font-weight: 700;
}

/* 进度条 */
.progress-wrap { margin-bottom: 24rpx; }
.progress-label {
  display: flex; justify-content: space-between;
  font-size: 24rpx; color: var(--text-hint); margin-bottom: 12rpx;
}
.pct { color: var(--primary); font-weight: 700; }
.progress-bar { height: 14rpx; background: var(--bg); border-radius: 8rpx; overflow: hidden; }
.progress-fill {
  height: 100%; border-radius: 8rpx;
  background: linear-gradient(90deg, #6C3CE1, #C77DFF);
  transition: width 0.5s ease;
}

/* 成员列表 */
.member-list { margin: 8rpx 0; }
.member-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 18rpx 0; border-bottom: 1rpx solid var(--border); font-size: 28rpx;
}
.member-item:last-child { border-bottom: none; }
.member-item.empty { opacity: 0.7; }
.m-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(108,60,225,0.1);
  display: flex; align-items: center; justify-content: center; font-size: 32rpx;
  flex-shrink: 0;
}
.m-avatar.empty {
  background: var(--bg); border: 3rpx dashed var(--border); font-size: 36rpx; color: var(--text-hint);
}
.m-avatar-img { width: 72rpx; height: 72rpx; border-radius: 50%; }
.m-info { flex: 1; display: flex; align-items: center; gap: 12rpx; }
.m-name { font-size: 28rpx; color: var(--text-main); font-weight: 500; }
.m-name.empty { color: var(--text-hint); }
.m-done { color: var(--success); font-size: 24rpx; font-weight: 700; }
.m-wait {
  display: flex; align-items: center; gap: 8rpx;
  background: rgba(108,60,225,0.06); border-radius: 24rpx; padding: 8rpx 20rpx;
  font-size: 22rpx; color: var(--primary); border: 2rpx solid rgba(108,60,225,0.15);
  font-weight: 600;
}

/* 商品信息卡片 */
.product-info-card { margin: 0 24rpx 24rpx; padding: 32rpx; }
.info-card-title { font-size: 28rpx; font-weight: 800; color: var(--text-main); margin-bottom: 24rpx; }
.info-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14rpx 0; border-bottom: 1rpx solid var(--border); font-size: 26rpx;
}
.info-row:last-child { border-bottom: none; }
.info-key { color: var(--text-hint); font-weight: 500; }
.info-val { color: var(--text-main); font-weight: 600; }
.info-val.purple { color: var(--primary); }
.info-val.green { color: var(--success); }

/* 底部操作栏（fixed） */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--card); border-top: 1rpx solid var(--border);
  display: flex; flex-direction: column; gap: 16rpx;
  box-shadow: 0 -4rpx 20rpx rgba(108,60,225,0.1);
}
.btn-join {
  background: linear-gradient(135deg, #6C3CE1 0%, #9B5DE5 100%);
  color: #fff; border: none; border-radius: 52rpx;
  font-size: 30rpx; font-weight: 800; padding: 24rpx 0; text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(108,60,225,0.4);
}
.btn-join::after { border: none; }
.btn-invite {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  width: 100%; padding: 22rpx; border-radius: 48rpx;
  background: rgba(108,60,225,0.06); color: var(--primary);
  font-size: 28rpx; font-weight: 700;
  border: 3rpx solid rgba(108,60,225,0.2);
}
.btn-invite.full { background: linear-gradient(135deg, #6C3CE1, #9B5DE5); color: #fff; border: none; }
.btn-invite::after { border: none; }
.success-tip {
  text-align: center; font-size: 28rpx; color: var(--success); font-weight: 600; padding: 16rpx 0;
}
.failed-tip {
  text-align: center; font-size: 28rpx; color: var(--text-hint); font-weight: 600; padding: 16rpx 0;
}
