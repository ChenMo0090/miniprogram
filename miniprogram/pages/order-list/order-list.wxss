/* pages/order-list/order-list.wxss */

.page { background: var(--bg); height: 100vh; display: flex; flex-direction: column; }

.nav-bar {
  background: #fff; padding: 0 28rpx; height: 90rpx;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}
.nav-back { color: var(--primary); font-size: 44rpx; }
.nav-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 800; color: var(--text-main); }

.tab-bar {
  display: flex; background: var(--card);
  border-bottom: 1rpx solid var(--border);
  overflow-x: auto; flex-shrink: 0;
}
.tab-bar::-webkit-scrollbar { display: none; }
.tab-item {
  flex-shrink: 0; padding: 24rpx 28rpx; font-size: 26rpx; font-weight: 500;
  color: var(--text-hint); white-space: nowrap;
  border-bottom: 5rpx solid transparent;
}
.tab-item.active { color: var(--primary); border-bottom-color: var(--primary); font-weight: 700; }

.list-wrap { flex: 1; padding: 20rpx; }

.order-card { margin-bottom: 20rpx; overflow: hidden; }

.order-card-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx 16rpx; border-bottom: 1rpx solid var(--border);
}
.order-no { font-size: 22rpx; color: var(--text-hint); font-weight: 500; }

.order-product {
  display: flex; gap: 20rpx; padding: 20rpx 24rpx;
  align-items: center;
}
.product-img-wrap {
  width: 120rpx; height: 120rpx; border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; overflow: hidden;
}
.product-img { width: 120rpx; height: 120rpx; }
.product-emoji { font-size: 56rpx; }
.img-bg1 { background: linear-gradient(135deg, #EDE9FE, #DDD6FE); }
.product-info { flex: 1; }
.product-name {
  font-size: 28rpx; color: var(--text-main); font-weight: 600;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  margin-bottom: 8rpx;
}
.product-spec { font-size: 24rpx; color: var(--text-hint); margin-bottom: 10rpx; display: block; }
.price-row { display: flex; align-items: center; gap: 16rpx; }
.price { font-size: 30rpx; font-weight: 800; color: var(--primary); }
.qty { font-size: 24rpx; color: var(--text-hint); }

.order-card-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx; border-top: 1rpx solid var(--border);
}
.order-time { font-size: 22rpx; color: var(--text-hint); }
.footer-actions { display: flex; gap: 16rpx; }
.btn-action {
  padding: 12rpx 28rpx; border-radius: 36rpx; font-size: 24rpx; font-weight: 700;
  border: 2rpx solid rgba(108,60,225,0.25); color: var(--primary);
  background: rgba(108,60,225,0.06);
}
.btn-action.primary {
  background: linear-gradient(135deg, #6C3CE1, #9B5DE5);
  color: #fff; border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(108,60,225,0.35);
}
.btn-action.green {
  color: var(--success); border-color: rgba(16,185,129,0.25);
  background: rgba(16,185,129,0.06);
}

.load-more, .no-more {
  text-align: center; padding: 40rpx 0; font-size: 26rpx; color: var(--text-hint);
}
