/* pages/group-list/group-list.wxss */

.page { background: var(--bg); min-height: 100vh; }

.home-top {
  background: linear-gradient(135deg, #6C3CE1 0%, #9B5DE5 50%, #C77DFF 100%);
  padding: 32rpx 28rpx 28rpx;
}
.top-title { font-size: 36rpx; font-weight: 800; color: #fff; margin-bottom: 8rpx; }
.top-sub { font-size: 24rpx; color: rgba(255,255,255,0.8); }

.tab-bar {
  display: flex; background: var(--card);
  border-bottom: 1rpx solid var(--border); overflow-x: auto;
}
.tab-bar::-webkit-scrollbar { display: none; }
.tab-item {
  flex-shrink: 0; padding: 24rpx 32rpx; font-size: 26rpx; font-weight: 500;
  color: var(--text-hint); white-space: nowrap;
  border-bottom: 5rpx solid transparent;
}
.tab-item.active { color: var(--primary); border-bottom-color: var(--primary); font-weight: 700; }

.group-list { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }

.group-card { overflow: hidden; }
.group-card-header {
  background: linear-gradient(135deg, #6C3CE1 0%, #9B5DE5 100%);
  padding: 22rpx 28rpx; display: flex; justify-content: space-between; align-items: center;
}
.gc-name { color: #fff; font-size: 28rpx; font-weight: 700; flex: 1; }
.gc-badge {
  background: rgba(255,255,255,0.2); color: #fff;
  font-size: 22rpx; font-weight: 700; padding: 6rpx 18rpx; border-radius: 24rpx;
}
.gc-badge.ended { background: rgba(255,255,255,0.12); }

.group-card-body { padding: 24rpx 28rpx; }
.gc-prog-label { font-size: 24rpx; color: var(--text-hint); margin-bottom: 16rpx; display: block; }
.progress-bar { height: 12rpx; background: var(--bg); border-radius: 6rpx; overflow: hidden; margin-bottom: 16rpx; }
.progress-fill {
  height: 100%; border-radius: 6rpx;
  background: linear-gradient(90deg, #6C3CE1, #C77DFF);
  transition: width 0.5s;
}
.avatars-row { display: flex; gap: 12rpx; margin: 16rpx 0 12rpx; }
.g-avatar {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; font-size: 28rpx; overflow: hidden;
}
.g-avatar.filled { background: rgba(108,60,225,0.1); }
.g-avatar.empty {
  background: var(--bg); border: 3rpx dashed var(--border);
  font-size: 24rpx; color: var(--text-hint);
}
.g-avatar-img { width: 60rpx; height: 60rpx; border-radius: 50%; }
.gc-timer { font-size: 24rpx; color: var(--primary); font-weight: 600; margin-bottom: 8rpx; }
.gc-price { font-size: 26rpx; color: var(--text-sub); }
.gc-price text { color: var(--primary); font-weight: 800; font-size: 30rpx; }

.group-card-footer {
  padding: 20rpx 28rpx; border-top: 1rpx solid var(--border); display: flex; gap: 16rpx;
}
.btn-sm {
  flex: 1; padding: 16rpx; border-radius: 36rpx; font-size: 26rpx; font-weight: 700;
  text-align: center; border: 3rpx solid rgba(108,60,225,0.25); color: var(--primary);
  background: rgba(108,60,225,0.05);
}
.btn-sm.primary {
  background: linear-gradient(135deg, #6C3CE1, #9B5DE5);
  color: #fff; border-color: transparent;
  box-shadow: 0 4rpx 20rpx rgba(108,60,225,0.35);
}
.btn-sm.disabled { background: var(--bg); color: var(--text-hint); border-color: var(--border); }

.btn-go-shop {
  background: linear-gradient(135deg, #6C3CE1, #9B5DE5); color: #fff;
  padding: 20rpx 60rpx; border-radius: 48rpx; font-size: 28rpx; font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(108,60,225,0.38); margin-top: 20rpx;
}

.login-tip {
  margin: 0 24rpx 40rpx; padding: 40rpx 28rpx;
  display: flex; flex-direction: column; align-items: center; gap: 24rpx;
}
.login-tip-text { font-size: 28rpx; color: var(--text-sub); font-weight: 500; }
.btn-login {
  background: linear-gradient(135deg, #6C3CE1, #9B5DE5); color: #fff;
  padding: 20rpx 80rpx; border-radius: 48rpx; font-size: 30rpx; font-weight: 800;
  box-shadow: 0 8rpx 32rpx rgba(108,60,225,0.4);
}

.load-more, .no-more {
  text-align: center; padding: 40rpx 0; font-size: 26rpx; color: var(--text-hint);
}
