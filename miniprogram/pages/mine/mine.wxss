/* pages/mine/mine.wxss */

.page { background: var(--bg); min-height: 100vh; }

/* 头部 */
.profile-header {
  background: linear-gradient(135deg, #6C3CE1 0%, #9B5DE5 50%, #C77DFF 100%);
  padding: 56rpx 28rpx 100rpx;
  display: flex; align-items: center; gap: 28rpx;
  position: relative; overflow: hidden;
}
.profile-bg {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 80% 50%, rgba(255,255,255,0.1) 0%, transparent 60%);
}
.avatar-wrap { position: relative; flex-shrink: 0; }
.avatar-img {
  width: 124rpx; height: 124rpx; border-radius: 50%;
  border: 5rpx solid rgba(255,255,255,0.45);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}
.avatar-placeholder {
  width: 124rpx; height: 124rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  border: 5rpx solid rgba(255,255,255,0.45); flex-shrink: 0;
}
.avatar-emoji { font-size: 60rpx; }
.profile-info { flex: 1; position: relative; }
.profile-name { font-size: 36rpx; font-weight: 800; color: #fff; }
.profile-sub { font-size: 24rpx; color: rgba(255,255,255,0.72); margin-top: 8rpx; }
.logout-btn {
  font-size: 24rpx; color: rgba(255,255,255,0.75); position: relative;
  background: rgba(255,255,255,0.12); padding: 8rpx 20rpx;
  border-radius: 30rpx; border: 1rpx solid rgba(255,255,255,0.2);
}

/* 统计卡片（悬浮效果） */
.stats-card {
  margin: -52rpx 28rpx 0;
  display: flex; align-items: center; justify-content: space-around;
  padding: 32rpx 20rpx; position: relative; z-index: 10;
  box-shadow: var(--shadow-md);
}
.stat-item { text-align: center; }
.stat-num { font-size: 40rpx; font-weight: 800; color: var(--primary); }
.stat-num.green { color: var(--success); }
.stat-label { font-size: 22rpx; color: var(--text-hint); margin-top: 6rpx; font-weight: 500; }
.stat-divider { width: 2rpx; height: 60rpx; background: var(--border); }

/* 菜单 */
.menu-section { margin: 28rpx 28rpx 0; }
.menu-section-title {
  font-size: 22rpx; color: var(--text-hint); font-weight: 600;
  margin-bottom: 16rpx; padding-left: 8rpx;
  text-transform: uppercase; letter-spacing: 1rpx;
}
.menu-card { overflow: hidden; }
.menu-item {
  display: flex; align-items: center; padding: 28rpx 28rpx; gap: 24rpx;
  border-bottom: 1rpx solid var(--border);
}
.menu-item:last-child { border-bottom: none; }
.menu-icon {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; flex-shrink: 0;
}
.mi-purple { background: rgba(108,60,225,0.1); }
.mi-green  { background: rgba(16,185,129,0.1);  }
.mi-blue   { background: rgba(59,130,246,0.1);  }
.mi-orange { background: rgba(245,158,11,0.1);  }
.menu-name { flex: 1; font-size: 28rpx; font-weight: 600; color: var(--text-main); }
.menu-arrow { color: var(--text-hint); font-size: 32rpx; }
.menu-badge {
  background: var(--danger); color: #fff; border-radius: 20rpx;
  font-size: 20rpx; font-weight: 700; padding: 4rpx 14rpx;
}

.version-tip {
  text-align: center; font-size: 22rpx; color: var(--text-hint);
  padding: 48rpx 0 80rpx;
}
