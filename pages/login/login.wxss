/* pages/login/login.wxss */

.page {
  min-height: 100vh; background: linear-gradient(160deg, #4A1FA8 0%, #6C3CE1 40%, #9B5DE5 70%, #F4F2FB 100%);
  display: flex; flex-direction: column; align-items: center;
  position: relative; overflow: hidden;
  padding: 0 40rpx;
}

/* 装饰圆 */
.bg-deco {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 80% 15%, rgba(240,180,41,0.2) 0%, transparent 45%),
              radial-gradient(circle at 20% 70%, rgba(199,125,255,0.25) 0%, transparent 40%);
}
.bg-circle1 {
  position: absolute; top: -120rpx; right: -120rpx;
  width: 400rpx; height: 400rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.bg-circle2 {
  position: absolute; bottom: 200rpx; left: -100rpx;
  width: 300rpx; height: 300rpx; border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

/* 品牌区 */
.brand-area {
  margin-top: 160rpx; text-align: center; position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: center;
}
.brand-icon { font-size: 120rpx; margin-bottom: 20rpx; }
.brand-name { font-size: 60rpx; font-weight: 900; color: #fff; letter-spacing: 2rpx; }
.brand-slogan {
  font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 14rpx;
  background: rgba(255,255,255,0.12); padding: 10rpx 28rpx; border-radius: 40rpx;
  border: 1rpx solid rgba(255,255,255,0.2); backdrop-filter: blur(8rpx);
}

/* 特性说明 */
.features {
  margin-top: 80rpx; display: flex; gap: 24rpx; position: relative; z-index: 1;
  width: 100%;
}
.feature-item {
  flex: 1; background: rgba(255,255,255,0.12); border-radius: var(--radius);
  border: 1rpx solid rgba(255,255,255,0.2); padding: 24rpx 16rpx;
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
  backdrop-filter: blur(8rpx);
}
.feature-icon { font-size: 48rpx; }
.feature-text { text-align: center; }
.ft-title { font-size: 26rpx; font-weight: 700; color: #fff; }
.ft-sub { font-size: 22rpx; color: rgba(255,255,255,0.7); margin-top: 4rpx; }

/* 登录区 */
.login-area {
  position: absolute; bottom: 80rpx; left: 40rpx; right: 40rpx; z-index: 1;
  display: flex; flex-direction: column; align-items: center; gap: 24rpx;
}
.btn-wx-login {
  width: 100%; padding: 30rpx 0;
  background: #fff; color: var(--primary);
  border: none; border-radius: 60rpx;
  font-size: 34rpx; font-weight: 800; text-align: center;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.2);
  letter-spacing: 1rpx;
}
.btn-wx-login::after { border: none; }
.btn-wx-login.loading { opacity: 0.7; }
.privacy-note { font-size: 22rpx; color: rgba(255,255,255,0.6); text-align: center; }
