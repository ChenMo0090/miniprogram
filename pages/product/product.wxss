/* pages/product/product.wxss */

.page { background: var(--bg); padding-bottom: env(safe-area-inset-bottom); }

/* 主图 */
.detail-img {
  width: 750rpx; height: 540rpx;
  background: linear-gradient(135deg, #EDE9FE 0%, #DDD6FE 50%, #C4B5FD 100%);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.main-img { width: 750rpx; height: 540rpx; }
.img-placeholder { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
.img-emoji { font-size: 180rpx; }

/* 价格区 */
.price-area {
  background: linear-gradient(135deg, #6C3CE1 0%, #9B5DE5 50%, #C77DFF 100%);
  padding: 28rpx 32rpx;
  display: flex; align-items: flex-start; justify-content: space-between;
  position: relative; overflow: hidden;
}
.price-area::after {
  content: ''; position: absolute; right: -40rpx; top: -40rpx;
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.price-left {}
.main-price { display: flex; align-items: baseline; gap: 4rpx; }
.price-unit { font-size: 30rpx; color: #fff; font-weight: 700; }
.price-num { font-size: 60rpx; font-weight: 900; color: #fff; line-height: 1; }
.orig-price { font-size: 24rpx; color: rgba(255,255,255,0.65); text-decoration: line-through; margin-top: 4rpx; }
.rating-row { display: flex; align-items: center; gap: 8rpx; margin-top: 8rpx; }
.rating-text { font-size: 22rpx; color: rgba(255,255,255,0.8); }
.stock-info {
  font-size: 22rpx; color: rgba(255,255,255,0.75);
  background: rgba(255,255,255,0.12); padding: 8rpx 16rpx; border-radius: 20rpx;
}

/* 商品名 */
.product-name-section {
  background: var(--card); padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
}
.product-title { font-size: 34rpx; font-weight: 800; color: var(--text-main); display: block; margin-bottom: 10rpx; }
.product-desc { font-size: 26rpx; color: var(--text-sub); line-height: 1.6; }

/* 拼团规则卡片 */
.group-rule-card {
  margin: 24rpx; padding: 28rpx;
  background: linear-gradient(135deg, #F5F0FF, #EDE8FF);
  border: 3rpx solid rgba(108,60,225,0.2);
  border-radius: var(--radius);
}
.rule-title {
  display: flex; align-items: center; gap: 12rpx;
  font-size: 28rpx; font-weight: 800; color: var(--primary); margin-bottom: 24rpx;
}
.rule-step {
  display: flex; align-items: flex-start; gap: 20rpx;
  margin-bottom: 16rpx;
}
.step-num {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: linear-gradient(135deg, #6C3CE1, #9B5DE5);
  color: #fff; font-size: 20rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(108,60,225,0.4);
}
.step-text { font-size: 26rpx; color: var(--text-sub); line-height: 1.6; padding-top: 6rpx; }
.refund-highlight {
  display: flex; align-items: center; justify-content: center; gap: 10rpx;
  background: linear-gradient(135deg, rgba(240,180,41,0.15), rgba(240,180,41,0.05));
  border: 2rpx solid rgba(240,180,41,0.4); border-radius: var(--radius-sm);
  padding: 18rpx 24rpx; margin-top: 20rpx;
  font-size: 26rpx; font-weight: 800; color: #8B6400; text-align: center;
}

/* 规格区 */
.spec-section {
  background: var(--card); margin-bottom: 16rpx;
}
.spec-row {
  display: flex; align-items: center; padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border); gap: 20rpx;
}
.spec-label { color: var(--text-sub); font-weight: 600; font-size: 28rpx; min-width: 56rpx; }
.spec-tags { display: flex; gap: 12rpx; flex-wrap: wrap; }
.spec-tag {
  padding: 10rpx 22rpx; border: 3rpx solid var(--border);
  border-radius: var(--radius-sm); font-size: 26rpx; color: var(--text-sub); font-weight: 500;
}
.spec-tag.active {
  background: rgba(108,60,225,0.08); border-color: var(--primary);
  color: var(--primary); font-weight: 700;
}
.qty-row {
  display: flex; align-items: center; padding: 24rpx 28rpx; gap: 20rpx;
}
.qty-label { color: var(--text-sub); font-weight: 600; font-size: 28rpx; min-width: 56rpx; }
.qty-ctrl { display: flex; align-items: center; gap: 0; border: 2rpx solid var(--border); border-radius: var(--radius-sm); overflow: hidden; }
.qty-btn {
  width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; color: var(--primary); background: rgba(108,60,225,0.04);
}
.qty-num {
  width: 80rpx; text-align: center; font-size: 30rpx; font-weight: 700;
  border-left: 2rpx solid var(--border); border-right: 2rpx solid var(--border);
  line-height: 72rpx;
}

/* 商品描述 */
.desc-section { background: var(--card); margin: 0 0 24rpx; padding: 28rpx; }
.desc-title { font-size: 28rpx; font-weight: 800; color: var(--text-main); margin-bottom: 16rpx; }
.desc-content { font-size: 26rpx; color: var(--text-sub); line-height: 1.8; }

/* 底部购买栏（fixed） */
.buy-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  background: var(--card); border-top: 1rpx solid var(--border);
  box-shadow: 0 -4rpx 20rpx rgba(108,60,225,0.1);
}
.btn-cart {
  width: 92rpx; height: 92rpx; border-radius: 50%;
  border: 3rpx solid var(--primary);
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; color: var(--primary);
  background: rgba(108,60,225,0.06); flex-shrink: 0;
}
.buy-btns { flex: 1; display: flex; gap: 16rpx; }
.btn-buy-normal {
  flex: 1; background: var(--bg); color: var(--primary);
  border: 3rpx solid rgba(108,60,225,0.3);
  border-radius: 52rpx; font-size: 28rpx; font-weight: 700;
  padding: 20rpx 0; text-align: center;
}
.btn-buy-group {
  flex: 1.5;
  background: linear-gradient(135deg, #6C3CE1 0%, #9B5DE5 100%);
  color: #fff; border: none; border-radius: 52rpx;
  font-size: 28rpx; font-weight: 800; padding: 20rpx 0; text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(108,60,225,0.42);
}
.share-btn {
  background: transparent; border: none; padding: 0;
  color: rgba(255,255,255,0.85); font-size: 26rpx; font-weight: 600;
  line-height: 1;
}
.share-btn::after { border: none; }
